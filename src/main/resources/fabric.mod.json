{
  "schemaVersion": 1,
  "id": "physics_toys",
  "version": "${version}",
  "name": "Physics Toys",
  "description": "Toy around with physics on your Minecraft server!",
  "authors": [
    "Patbox"
  ],
  "contributors": [
    "unilock"
  ],
  "contact": {
    "homepage": "https://pb4.eu",
    "sources": "https://github.com/Patbox/PhysicsToys"
  },

  "license": "LGPL-3.0",
  "icon": "assets/physics_toys/icon.png",

  "environment": "*",
  "entrypoints": {
    "main": [
      "eu.pb4.physicstoys.PhysicsToysMod"
    ],
    "fabric-datagen": [
      "eu.pb4.physicstoys.datagen.DataGenInit"
    ],
    "preLaunch": ["eu.pb4.physicstoys.other.CardboardWarning"]
  },
  "mixins": [
    "pbrayon.mixins.json"
  ],
  "accessWidener": "physicstoys.accesswidener",
  "depends": {
    "fabricloader": "*",
    "fabric-api": "*",
    "minecraft": ">=26.1",
    "java": ">=25"
  }
}
